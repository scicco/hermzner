#!/bin/bash
set -euo pipefail

BACKUP_DIR="{{ hermes_backup_dir }}"
DATA_DIR="{{ hermes_data_dir }}"
RETENTION_DAYS={{ backup_retention_days }}
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
ARCHIVE="${BACKUP_DIR}/hermes-backup-${TIMESTAMP}.tar.gz"
ENCRYPTED="${ARCHIVE}.age"
AGE_RECIPIENT="{{ backup_age_recipient }}"

if [ "${BACKUP_DIR}" = "/" ] || [ -z "${BACKUP_DIR}" ]; then
  echo "ERROR: BACKUP_DIR is invalid" >&2
  exit 1
fi

[ -d "${DATA_DIR}" ] || { echo "ERROR: DATA_DIR does not exist" >&2; exit 1; }

mkdir -p "${BACKUP_DIR}"

tar czf "${ARCHIVE}" -C "$(dirname "${DATA_DIR}")" "$(basename "${DATA_DIR}")"

{% if backup_encryption_enabled %}
if ! command -v age >/dev/null 2>&1; then
  echo "ERROR: backup encryption enabled but age is not installed" >&2
  rm -f "${ARCHIVE}"
  exit 1
fi

if [ -z "${AGE_RECIPIENT}" ]; then
  echo "ERROR: backup encryption enabled but AGE_RECIPIENT is empty" >&2
  rm -f "${ARCHIVE}"
  exit 1
fi

age -r "${AGE_RECIPIENT}" -o "${ENCRYPTED}" "${ARCHIVE}"
chmod 0600 "${ENCRYPTED}"
rm -f "${ARCHIVE}"
echo "Encrypted backup: ${ENCRYPTED}"
{% else %}
chmod 0600 "${ARCHIVE}"
echo "Backup: ${ARCHIVE}"
{% endif %}

find "${BACKUP_DIR}" -name "hermes-backup-*" -type f -mtime +"${RETENTION_DAYS}" -delete
